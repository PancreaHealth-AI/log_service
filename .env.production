# Production Environment Configuration
PORT=3001
NODE_ENV=production

# Elasticsearch Configuration - Production
ELASTICSEARCH_NODE=https://elasticsearch.example.com:9200
ELASTICSEARCH_USER=prod_elastic_user
ELASTICSEARCH_PASS=your_secure_password_here

# Kafka Configuration - Production
KAFKA_BROKERS=kafka-broker-1:9092,kafka-broker-2:9092,kafka-broker-3:9092

# Log Level
LOG_LEVEL=info

# Service Name
SERVICE_NAME=audit-log-service
